<body>

  <script>
    function alerta()
    {
      console.log("Alerta");
    
      setTimeout(() => {
        console.log("Alerta");
      },3000);
    setInterval(() => {
        console.log("Alerta");
      },3000);
    }
    
//PROMISSE  - 
function buscaDadosdoServidor(){
  return new Promise((resolve,reject) =>{
    console.log("Buscando dados no seridor....");
    setTimeout(() => {
      let sucesso = Math.random() > 0.5;

      if(sucesso){
        resolve("Dados recebidos com sucesso");
      }else{
        reject("Falta ao buscar dados ao servidor");
      }
    },2000);
  });
}
console.log("Inicio da aexecução");
buscaDadosdoServidor()
    .then((mensagem) => {
      console.log(mensagem);
    })
    .catch((erro) => {
      console.error(erro);
    });
   
   console.log("Final da execução.");
</script>
</body>
</html>
